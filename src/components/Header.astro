---
const { title = 'Jonathan Van der Cruysse' } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const crumbTitle = title === 'Jonathan Van der Cruysse' ? '' : title;

const parentCrumbs = [
  { match: /^\/publication\//, href: '/publications/', label: 'Publications' },
  { match: /^\/talks\/.+/, href: '/talks/', label: 'Talks' },
  { match: /^\/teaching\/.+/, href: '/teaching/', label: 'Teaching' },
  { match: /^\/projects\//, href: '/compiler-work/', label: 'Compiler Work' },
  { match: /^\/portfolio\//, href: '/compiler-work/', label: 'Compiler Work' }
];

const parentCrumb = parentCrumbs.find((crumb) => crumb.match.test(currentPath));
---

<header class="site-header">
  <nav class="site-crumb" aria-label="Breadcrumb">
    <a class="site-crumb__home" href="/">Jonathan Van der Cruysse</a>
    {parentCrumb && (
      <>
        <span aria-hidden="true">/</span>
        <a href={parentCrumb.href}>{parentCrumb.label}</a>
      </>
    )}
    {!isHome && crumbTitle && (
      <>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{crumbTitle}</span>
      </>
    )}
  </nav>
  <a class="site-header__resume" href="/files/resume.pdf">Resume PDF</a>
</header>
