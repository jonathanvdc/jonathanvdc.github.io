---
const { entry, meta = [], eyebrow, links = [], badges = [] } = Astro.props;
const { frontmatter } = entry;
const railItems = Array.isArray(eyebrow) ? eyebrow.filter(Boolean) : [eyebrow].filter(Boolean);
---

<li class="archive-card">
  <a class="archive-card__overlay" href={entry.url} aria-label={`Read more about ${frontmatter.title}`}></a>
  <div class="archive-card__rail">
    {railItems.map((item) => <span>{item}</span>)}
  </div>
  <div class="archive-card__body">
    <div class="archive-card__title-row">
      <h2><a href={entry.url}>{frontmatter.title}</a></h2>
      {badges.length > 0 && (
        <ul class="artifact-badges" aria-label="Artifact evaluation badges">
          {badges.map((badge) => (
            <li>
              <img src={badge.src} alt={badge.alt} loading="lazy" />
            </li>
          ))}
        </ul>
      )}
    </div>
    {frontmatter.authors && <p class="authors">{frontmatter.authors}</p>}
    {meta.length > 0 && <p class="metadata">{meta.filter(Boolean).join(' · ')}</p>}
    {frontmatter.excerpt && <p>{frontmatter.excerpt}</p>}
    {links.length > 0 && (
      <div class="archive-card__links">
        {links.map((link) => (
          <a href={link.href}>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</li>
