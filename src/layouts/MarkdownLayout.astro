---
import BaseLayout from './BaseLayout.astro';
import { compact, formatDate } from '../lib/content.js';

const { entry, eyebrow, badges = [] } = Astro.props;
const { frontmatter, Content } = entry;
const metadata = compact([
  frontmatter.type,
  frontmatter.venue,
  frontmatter.location,
  frontmatter.date && formatDate(frontmatter.date)
]);
---

<BaseLayout title={frontmatter.title} description={frontmatter.excerpt ?? frontmatter.title} showSidebar={false}>
  <article class="article">
    {(eyebrow || badges.length > 0) && (
      <div class="article__eyebrow-row">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {badges.length > 0 && (
          <ul class="artifact-badges" aria-label="Artifact evaluation badges">
            {badges.map((badge) => (
              <li>
                <img src={badge.src} alt={badge.alt} loading="lazy" />
              </li>
            ))}
          </ul>
        )}
      </div>
    )}
    <h1 class="article__title">{frontmatter.title}</h1>
    {frontmatter.authors && <p class="authors">{frontmatter.authors}</p>}
    {metadata.length > 0 && <p class="metadata">{metadata.join(' · ')}</p>}
    {frontmatter.excerpt && <p class="dek">{frontmatter.excerpt}</p>}
    <div class="action-row">
      {frontmatter.paperurl && <a class="button" href={frontmatter.paperurl}>Paper PDF</a>}
      {frontmatter.slidesurl && <a class="button button--secondary" href={frontmatter.slidesurl}>Slides</a>}
    </div>
    <Content />
  </article>
</BaseLayout>
