---
import Header from '../components/Header.astro';
import AuthorSidebar from '../components/AuthorSidebar.astro';
import SiteLinks from '../components/SiteLinks.astro';
import Footer from '../components/Footer.astro';
import '../styles/site.css';

const {
  title = 'Jonathan Van der Cruysse',
  description = 'Compiler engineer specializing in optimizations, IR design, and equality saturation',
  showSidebar = true
} = Astro.props;

const pageTitle = title === 'Jonathan Van der Cruysse'
  ? title
  : `${title} | Jonathan Van der Cruysse`;
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8f2e5" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/images/site-logo.png" />
  </head>
  <body>
    <div class="shell">
      <Header title={title} />
      <main class:list={['page-grid', !showSidebar && 'page-grid--single']}>
        {showSidebar && <AuthorSidebar />}
        <section class="content-panel">
          <slot />
        </section>
      </main>
      {!isHome && <SiteLinks />}
      <Footer />
    </div>
  </body>
</html>
