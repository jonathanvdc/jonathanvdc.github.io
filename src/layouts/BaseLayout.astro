---
import Header from '../components/Header.astro';
import AuthorSidebar from '../components/AuthorSidebar.astro';
import SiteLinks from '../components/SiteLinks.astro';
import Footer from '../components/Footer.astro';
import '../styles/site.css';

const {
  title = 'Jonathan Van der Cruysse',
  description = 'Compiler engineer specializing in optimizations, IR design, and equality saturation',
  showSidebar = true,
  image = '/images/profile.png',
  type = 'website'
} = Astro.props;

const pageTitle = title === 'Jonathan Van der Cruysse'
  ? title
  : `${title} | Jonathan Van der Cruysse`;
const isHome = Astro.url.pathname === '/';
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const socialImageUrl = new URL(image, site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8f2e5" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/images/site-logo.png" />
  </head>
  <body>
    <div class="shell">
      <Header title={title} />
      <main class:list={['page-grid', !showSidebar && 'page-grid--single']}>
        {showSidebar && <AuthorSidebar />}
        <section class="content-panel">
          <slot />
        </section>
      </main>
      {!isHome && <SiteLinks />}
      <Footer />
    </div>
  </body>
</html>
