---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveEntryCard from '../../components/ArchiveEntryCard.astro';
import ArchiveHero from '../../components/ArchiveHero.astro';
import { byDateDesc, entriesFromGlob, formatDate } from '../../lib/content.js';

const teaching = entriesFromGlob(
  'teaching',
  import.meta.glob('../../../_teaching/*.md', { eager: true })
).sort(byDateDesc);

const teachingYears = teaching
  .map((entry) => new Date(entry.frontmatter.date).getUTCFullYear())
  .filter(Boolean);
const teachingSpan = `${Math.min(...teachingYears)}-${Math.max(...teachingYears)}`;
---

<BaseLayout title="Teaching" description="Teaching assistant and instructional work." showSidebar={false}>
  <section class="archive-page">
    <ArchiveHero
      eyebrow="Teaching"
      title="Teaching"
      description="Teaching and mentorship across programming, algorithms, software design, programming languages, and compiler construction."
      stats={[`${teaching.length} course roles`, teachingSpan, 'programming · PL · compilers']}
      tone="teaching"
    />

    <ol class="archive-list">
      {teaching.map((entry) => (
        <ArchiveEntryCard
          entry={entry}
          eyebrow={formatDate(entry.frontmatter.date, { year: 'numeric', month: undefined })}
          meta={[entry.frontmatter.type, entry.frontmatter.terms, entry.frontmatter.venue, formatDate(entry.frontmatter.date)]}
        />
      ))}
    </ol>
  </section>
</BaseLayout>
