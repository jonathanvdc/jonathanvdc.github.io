---
import MarkdownLayout from '../../layouts/MarkdownLayout.astro';
import RedirectPage from '../../components/RedirectPage.astro';
import { entriesFromGlob } from '../../lib/content.js';

export function getStaticPaths() {
  const entries = entriesFromGlob(
    'portfolio',
    import.meta.glob('../../../_portfolio/*.md', { eager: true })
  );

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const canonicalWorkUrl = entry.frontmatter.work_slug && `/compiler-work/${entry.frontmatter.work_slug}/`;
---

{canonicalWorkUrl ? <RedirectPage to={canonicalWorkUrl} /> : <MarkdownLayout entry={entry} eyebrow="Compiler Work" />}
