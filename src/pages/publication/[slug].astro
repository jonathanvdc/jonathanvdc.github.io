---
import MarkdownLayout from '../../layouts/MarkdownLayout.astro';
import RedirectPage from '../../components/RedirectPage.astro';
import { badgesFromKeys } from '../../lib/artifactBadges.js';
import { entriesFromGlob } from '../../lib/content.js';

export function getStaticPaths() {
  const entries = entriesFromGlob(
    'publication',
    import.meta.glob('../../../_publications/*.md', { eager: true })
  );

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const badges = badgesFromKeys(entry.frontmatter.artifact_badges);
const canonicalWorkUrl = entry.frontmatter.work_slug && `/compiler-work/${entry.frontmatter.work_slug}/`;
---

{canonicalWorkUrl ? <RedirectPage to={canonicalWorkUrl} /> : <MarkdownLayout entry={entry} eyebrow="Publication" badges={badges} />}
