---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { badgesFromKeys } from '../../lib/artifactBadges.js';
import { byDateDesc, compact, entriesFromGlob, formatDate } from '../../lib/content.js';
import { compilerProjects } from '../../data/compilerProjects.js';

export function getStaticPaths() {
  return compilerProjects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;

const publications = entriesFromGlob(
  'publication',
  import.meta.glob('../../../_publications/*.md', { eager: true })
)
  .filter((entry) => entry.frontmatter.work_slug === project.id)
  .sort(byDateDesc);

const talks = entriesFromGlob(
  'talks',
  import.meta.glob('../../../_talks/*.md', { eager: true })
)
  .filter((entry) => entry.frontmatter.work_slug === project.id)
  .sort(byDateDesc);

const projectEntries = [
  ...entriesFromGlob('portfolio', import.meta.glob('../../../_portfolio/*.md', { eager: true })),
  ...entriesFromGlob('projects', import.meta.glob('../../../_projects/*.md', { eager: true }))
].filter((entry) => entry.frontmatter.work_slug === project.id);

const primaryEntry = projectEntries[0] ?? publications[0];
const PrimaryContent = primaryEntry?.Content;
const pageDescription = primaryEntry?.frontmatter.excerpt ?? project.blurb;
const projectVisual = project.mask ?? project.image;
const heroStyle = projectVisual
  ? `--work-from: ${projectVisual.from}; --work-to: ${projectVisual.to};`
  : undefined;
const outputItems = [
  ...publications.map((entry) => ({ type: 'publication', entry })),
  ...talks.map((entry) => ({ type: 'talk', entry }))
];
const outputTitle = describeOutputs(publications.length, talks.length);
const outputEyebrowLabel = describeOutputEyebrow(publications.length, talks.length);

function countLabel(count, singular, plural = `${singular}s`) {
  if (count === 0) {
    return undefined;
  }

  return count === 1 ? singular : `${count} ${plural}`;
}

function joinLabels(labels) {
  if (labels.length <= 2) {
    return labels.join(' and ');
  }

  return `${labels.slice(0, -1).join(', ')}, and ${labels.at(-1)}`;
}

function describeOutputs(publicationCount, talkCount) {
  return joinLabels(compact([
    countLabel(publicationCount, 'Peer-reviewed paper', 'papers'),
    countLabel(talkCount, 'talk', 'talks')
  ]));
}

function describeOutputEyebrow(publicationCount, talkCount) {
  if (publicationCount > 0 && talkCount > 0) {
    return publicationCount === 1 && talkCount === 1
      ? 'Paper + talk'
      : 'Papers + talks';
  }

  return publicationCount > 0
    ? countLabel(publicationCount, 'Publication', 'Publications')
    : countLabel(talkCount, 'Talk', 'Talks');
}

function outputEyebrow(type, entry) {
  const kind = type === 'publication' ? 'Paper' : 'Talk';
  const year = formatDate(entry.frontmatter.date, { year: 'numeric', month: undefined });

  return compact([kind, compact([entry.frontmatter.venue_abbreviation, year]).join(' ')]).join(' · ');
}

function citationLines(citation) {
  return citation.trimEnd().split('\n').map((line) => {
    const indent = line.match(/^\s*/)?.[0].length ?? 0;

    return {
      indent,
      text: line.slice(indent)
    };
  });
}
---

<BaseLayout title={project.title} description={pageDescription} showSidebar={false}>
  <article class="work-detail">
    <section class="work-hero" style={heroStyle}>
      <div class="work-hero__heading">
        <p class="eyebrow">{project.subtitle}</p>
        <h1>{project.title}</h1>
      </div>
      <div class="work-hero__summary">
        <p>{project.blurb}</p>
        <div class="action-row">
          {project.links.map((link) => <a class="button button--secondary" href={link.href}>{link.label}</a>)}
        </div>
      </div>
      {project.mask ? (
        <div class="work-hero__mark" aria-hidden="true">
          <div
            class="work-hero__mark-art"
            style={`--mark-image: url('${project.mask.src}');`}
          ></div>
        </div>
      ) : project.image ? (
        <div class="work-hero__mark" aria-hidden="true">
          <img src={project.image.src} alt="" loading="lazy" />
        </div>
      ) : null}
      <dl class="work-hero__facts">
        <div>
          <dt>Impact</dt>
          <dd>{project.impact}</dd>
        </div>
        <div>
          <dt>Role</dt>
          <dd>{project.role}</dd>
        </div>
        <div>
          <dt>Stack</dt>
          <dd>{project.tech.join(' · ')}</dd>
        </div>
      </dl>
    </section>

    {outputItems.length > 0 && (
      <section class="work-section">
        <div class="work-section__heading">
          <p class="eyebrow">{outputEyebrowLabel}</p>
          <h2>{outputTitle}</h2>
        </div>
        <div class="work-evidence-list">
          {outputItems.map(({ type, entry }) => {
            const isPublication = type === 'publication';
            const badges = badgesFromKeys(entry.frontmatter.artifact_badges);
            const metadata = compact([
              entry.frontmatter.venue,
              type === 'talk' && entry.frontmatter.location,
              formatDate(entry.frontmatter.date)
            ]);

            return (
              <section
                id={`${type}-${entry.slug}`}
                class:list={[
                  isPublication ? 'work-evidence work-evidence--publication' : 'work-talk'
                ]}
              >
                <div class="work-evidence__title-row">
                  <div>
                    <p class="work-evidence__eyebrow">{outputEyebrow(type, entry)}</p>
                    <h3>{entry.frontmatter.title}</h3>
                  </div>
                  {isPublication && badges.length > 0 && (
                    <ul class="artifact-badges" aria-label="Artifact evaluation badges">
                      {badges.map((badge) => (
                        <li>
                          <img src={badge.src} alt={badge.alt} loading="lazy" />
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
                {isPublication && entry.frontmatter.authors && <p class="authors">{entry.frontmatter.authors}</p>}
                {metadata.length > 0 && <p class="metadata">{metadata.join(' · ')}</p>}
                {isPublication && entry.frontmatter.excerpt && <p class="dek">{entry.frontmatter.excerpt}</p>}
                {isPublication ? (
                  <div class="action-row">
                    {entry.frontmatter.paperurl && <a class="button" href={entry.frontmatter.paperurl}>Paper PDF</a>}
                    {entry.frontmatter.slidesurl && <a class="button button--secondary" href={entry.frontmatter.slidesurl}>Slides</a>}
                  </div>
                ) : (
                  <div class="archive-card__links">
                    {entry.frontmatter.slidesurl && (
                      <a href={entry.frontmatter.slidesurl}>
                        <span>Slides</span>
                      </a>
                    )}
                  </div>
                )}
                {isPublication && entry.frontmatter.bibtex && (
                  <details class="citation-card">
                    <summary>
                      <span>BibTeX citation</span>
                    </summary>
                    <div class="citation-card__body">
                      <button class="citation-card__copy" type="button" data-copy-citation>
                        Copy
                      </button>
                      <pre><code>{citationLines(entry.frontmatter.bibtex).map((line) => <span class="citation-card__line" data-indent={line.indent} style={`--indent: ${line.indent}ch`}>{line.text}</span>)}</code></pre>
                    </div>
                  </details>
                )}
              </section>
            );
          })}
        </div>
      </section>
    )}

    {PrimaryContent && (
      <section class="work-section work-section--narrative">
        <div class="work-section__heading">
          <p class="eyebrow">Technical story</p>
          <h2>How the system works</h2>
        </div>
        <div class="article">
          <PrimaryContent />
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
  document.querySelectorAll('[data-copy-citation]').forEach((button) => {
    button.addEventListener('click', async () => {
      const lines = button.closest('.citation-card')?.querySelectorAll('.citation-card__line');
      const citation = Array.from(lines ?? [])
        .map((line) => `${' '.repeat(Number(line.dataset.indent ?? 0))}${line.textContent?.trimEnd() ?? ''}`)
        .join('\n')
        .trim();
      if (!citation) {
        return;
      }

      await navigator.clipboard.writeText(citation);
      const originalLabel = button.textContent;
      button.textContent = 'Copied';
      window.setTimeout(() => {
        button.textContent = originalLabel;
      }, 1400);
    });
  });
</script>
