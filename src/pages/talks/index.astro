---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveEntryCard from '../../components/ArchiveEntryCard.astro';
import ArchiveHero from '../../components/ArchiveHero.astro';
import { byDateDesc, entriesFromGlob, formatDate } from '../../lib/content.js';

const talks = entriesFromGlob(
  'talks',
  import.meta.glob('../../../_talks/*.md', { eager: true })
).sort(byDateDesc);

const locationSummary = 'Sydney · Toronto · Edinburgh · Athens';
---

<BaseLayout title="Talks" description="Conference talks, presentations, and invited talks." showSidebar={false}>
  <section class="archive-page">
    <ArchiveHero
      eyebrow="Speaking"
      title="Talks"
      description="Conference talks and workshop presentations on compiler optimization, equality saturation, FPGA compilation, and program representation."
      stats={[`${talks.length} talks`, 'CGO · CC · CDP · SPLASH', locationSummary]}
      tone="speaking"
    />

    <ol class="archive-list">
      {talks.map((entry) => {
        const canonicalHref = entry.frontmatter.work_slug
          ? `/compiler-work/${entry.frontmatter.work_slug}/#talk-${entry.slug}`
          : entry.url;
        const links = [
          entry.frontmatter.slidesurl && { label: 'Slides', href: entry.frontmatter.slidesurl },
          entry.frontmatter.paperurl && { label: 'Paper', href: entry.frontmatter.paperurl }
        ].filter(Boolean);

        return (
          <ArchiveEntryCard
            entry={entry}
            href={canonicalHref}
            eyebrow={[
              entry.frontmatter.venue_abbreviation,
              formatDate(entry.frontmatter.date, { year: 'numeric', month: undefined })
            ]}
            meta={[entry.frontmatter.venue, entry.frontmatter.location, formatDate(entry.frontmatter.date)]}
            links={links}
          />
        );
      })}
    </ol>
  </section>
</BaseLayout>
