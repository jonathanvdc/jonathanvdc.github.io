---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompilerProjectCard from '../components/CompilerProjectCard.astro';
import { compilerProjects } from '../data/compilerProjects.js';

const featuredProjects = compilerProjects.filter((project) => project.featured);
const supportingProjects = compilerProjects.filter((project) => !project.featured);
---

<BaseLayout title="Compiler Work" description="Compiler systems and research projects most relevant to compiler engineering roles." showSidebar={false}>
  <section class="compiler-showcase">
    <div class="compiler-hero">
      <p class="eyebrow">Compiler Systems Portfolio</p>
      <h1>Optimizing compilers and runtimes.</h1>
      <p>
        I build compiler infrastructure for program optimization, equality
        saturation, hardware-aware compilation, managed runtimes, and MLIR
        tooling. The projects below span research prototypes, open-source
        infrastructure, and production-minded systems work.
      </p>
      <div class="action-row">
        <a class="button" href="/files/resume.pdf">Resume PDF</a>
        <a class="button button--secondary" href="https://github.com/jonathanvdc">GitHub</a>
        <a class="button button--secondary" href="mailto:jonathan.vandercruysse@mail.mcgill.ca">Email</a>
      </div>
    </div>

    <div class="compiler-section-heading">
      <p class="eyebrow">Featured Systems</p>
      <h2>Recent compiler research</h2>
    </div>
    <div class="compiler-grid compiler-grid--featured">
      {featuredProjects.map((project) => <CompilerProjectCard project={project} />)}
    </div>

    <div class="compiler-section-heading">
      <p class="eyebrow">Compiler Infrastructure</p>
      <h2>IRs, runtimes, and optimizers</h2>
    </div>
    <div class="compiler-grid">
      {supportingProjects.map((project) => <CompilerProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
