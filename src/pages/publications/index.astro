---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveEntryCard from '../../components/ArchiveEntryCard.astro';
import ArchiveHero from '../../components/ArchiveHero.astro';
import { byDateDesc, entriesFromGlob, formatDate } from '../../lib/content.js';

const publications = entriesFromGlob(
  'publication',
  import.meta.glob('../../../_publications/*.md', { eager: true })
).sort(byDateDesc);

const stats = [
  `${publications.length} peer-reviewed papers`,
  'CGO · CC · SPLASH',
  'papers, slides, artifacts'
];

const artifactBadges = {
  available: {
    src: '/images/artifact-evaluation-badges/artifacts_available_v1_1.svg',
    alt: 'Artifact Available'
  },
  reusable: {
    src: '/images/artifact-evaluation-badges/artifacts_evaluated_reusable_v1_1.svg',
    alt: 'Artifact Reusable'
  },
  'results-reproduced': {
    src: '/images/artifact-evaluation-badges/results_reproduced_v1_1.svg',
    alt: 'Results Reproduced'
  }
};
---

<BaseLayout title="Publications" description="Peer-reviewed publications by Jonathan Van der Cruysse." showSidebar={false}>
  <section class="archive-page">
    <ArchiveHero
      eyebrow="Research"
      title="Publications"
      description="Peer-reviewed compiler systems work on equality saturation, IR design, FPGA compilation, source code rewriting, and idiom recognition."
      stats={stats}
      tone="research"
    />

    <ol class="archive-list">
      {publications.map((entry) => {
        const links = [
          entry.frontmatter.paperurl && { label: 'PDF', href: entry.frontmatter.paperurl },
          entry.frontmatter.slidesurl && { label: 'Slides', href: entry.frontmatter.slidesurl }
        ].filter(Boolean);
        const badges = (entry.frontmatter.artifact_badges ?? [])
          .map((badge) => artifactBadges[badge])
          .filter(Boolean);

        return (
          <ArchiveEntryCard
            entry={entry}
            eyebrow={[
              entry.frontmatter.venue_abbreviation,
              formatDate(entry.frontmatter.date, { year: 'numeric', month: undefined })
            ]}
            meta={[entry.frontmatter.venue, formatDate(entry.frontmatter.date)]}
            links={links}
            badges={badges}
          />
        );
      })}
    </ol>
  </section>
</BaseLayout>
